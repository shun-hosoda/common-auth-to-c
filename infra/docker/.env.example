############################################################
# Supabase OSS セルフホスト — 環境変数サンプル
# 実際の値は .env にコピーして設定する（.env は .gitignore済み）
############################################################

# PostgreSQL
POSTGRES_PASSWORD=your-super-secret-db-password
POSTGRES_DB=postgres

# JWT シークレット（openssl rand -base64 32 で生成）
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
# アクセストークン有効期限（秒）— ADR-003: 15分
JWT_EXPIRY=900

# Supabase API キー（supabase-js / @supabase/ssr で使用）
# anon key: JWT payload { role: "anon" } を JWT_SECRET で署名した値
ANON_KEY=your-anon-key
# service_role key: JWT payload { role: "service_role" } を JWT_SECRET で署名した値
# ⚠️ NEXT_PUBLIC_ プレフィックス厳禁。Server Action / Route Handler のみで使用
SERVICE_ROLE_KEY=your-service-role-key

# GoTrue (Supabase Auth) 設定
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/auth/callback

# Google OAuth（Google Cloud Console で取得）
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
GOTRUE_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/v1/callback

# メール送信（開発環境は inbucket を使用）
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=inbucket
SMTP_PORT=2500
SMTP_SENDER_NAME=common-auth-to-c

# Next.js からの接続情報（frontend/.env.local にも設定する）
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
