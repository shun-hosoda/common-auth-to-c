# Next.js 環境変数サンプル
# cp .env.local.example .env.local して設定する（.env.local は .gitignore済み）

# Supabase 接続情報（infra/docker/.env と合わせる）
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role key — ⚠️ NEXT_PUBLIC_ 厳禁。Server Action / Route Handler のみで使用
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
